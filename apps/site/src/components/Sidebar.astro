---
import { SITE_TITLE, SITE_TAGLINE, GITHUB_URL } from "../consts";

// Normalize the current path (strip trailing slash) so nav links highlight the
// active page regardless of trailing-slash form.
const path = Astro.url.pathname.replace(/\/+$/, "") || "/";

const navItems = [
  { href: "/", label: "Home", match: "/" },
  { href: "/about/", label: "About", match: "/about" },
];

const isActive = (match: string) =>
  match === "/" ? path === "/" : path === match || path.startsWith(match + "/");
---

<aside id="sidebar">
  <div class="profile">
    <a href="/" class="avatar" aria-label={`${SITE_TITLE} — home`}>
      <img
        src="/logo-full.png"
        width="112"
        height="112"
        alt={`${SITE_TITLE} logo`}
      />
    </a>
    <a href="/" class="site-title">{SITE_TITLE}</a>
    <p class="site-tagline">{SITE_TAGLINE}</p>
  </div>

  <nav class="sidebar-nav" aria-label="Primary">
    <ul>
      {
        navItems.map((item) => (
          <li>
            <a
              href={item.href}
              class:list={["nav-link", { active: isActive(item.match) }]}
              aria-current={isActive(item.match) ? "page" : undefined}
            >
              {item.label === "Home" ? (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M12 3l9 8h-3v9h-4v-6h-4v6H6v-9H3z"
                  />
                </svg>
              ) : (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path
                    fill="currentColor"
                    d="M11 7h2v2h-2zm0 4h2v6h-2zm1-9a10 10 0 100 20 10 10 0 000-20zm0 18a8 8 0 110-16 8 8 0 010 16z"
                  />
                </svg>
              )}
              <span>{item.label.toUpperCase()}</span>
            </a>
          </li>
        ))
      }
    </ul>
  </nav>

  <div class="sidebar-bottom">
    <a
      href={GITHUB_URL}
      aria-label="GitHub"
      target="_blank"
      rel="noopener noreferrer"
    >
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M12 .5a12 12 0 00-3.8 23.4c.6.1.8-.3.8-.6v-2c-3.3.7-4-1.6-4-1.6-.6-1.4-1.3-1.8-1.3-1.8-1.1-.7 0-.7 0-.7 1.2 0 1.9 1.2 1.9 1.2 1 1.8 2.8 1.3 3.5 1 .1-.8.4-1.3.7-1.6-2.7-.3-5.5-1.3-5.5-5.9 0-1.3.5-2.4 1.2-3.2 0-.4-.5-1.6.2-3.2 0 0 1-.3 3.3 1.2a11.5 11.5 0 016 0C17 5 18 5.3 18 5.3c.7 1.6.2 2.8.1 3.2.8.8 1.2 1.9 1.2 3.2 0 4.6-2.8 5.6-5.5 5.9.4.4.8 1.1.8 2.2v3.3c0 .3.2.7.8.6A12 12 0 0012 .5z"
        ></path>
      </svg>
    </a>
    <a href="/rss.xml" aria-label="RSS feed">
      <svg viewBox="0 0 24 24" aria-hidden="true">
        <path
          fill="currentColor"
          d="M6.2 15.6a2.2 2.2 0 100 4.4 2.2 2.2 0 000-4.4zM4 4v3.1a12.9 12.9 0 0112.9 12.9H20A15.9 15.9 0 004 4zm0 5.6V13a7 7 0 017 7h3.4A10.4 10.4 0 004 9.6z"
        ></path>
      </svg>
    </a>
  </div>
</aside>
